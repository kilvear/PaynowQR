{
  "name": "paynowqr",
  "version": "1.1.2",
  "description": "Singapore Paynow QR generator for node.js and javascript",
  "main": "dist/paynowqr.umd.js",
  "module": "dist/paynowqr.esm.js",
  "unpkg": "dist/paynowqr.min.js",
  "files": [
    "/dist"
  ],
  "dependencies": {
    "dayjs": "^1.8.26"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@rollup/plugin-commonjs": "^11.1.0",
    "@rollup/plugin-node-resolve": "^7.1.3",
    "http-server": "^14.1.1",
    "rollup": "^2.10.0",
    "terser": "^5.31.0"
  },
  "scripts": {
    "build": "rollup --config && npx terser dist/paynowqr.js -o dist/paynowqr.min.js -c -m",
    "postbuild": "node scripts/postbuild-copy.js",
    "test": "node example",
    "test:e2e": "playwright test",
    "release": "np --branch production"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ThunderQuoteTeam/PaynowQR.git"
  },

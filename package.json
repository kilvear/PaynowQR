  "bugs": {
    "url": "https://github.com/ThunderQuoteTeam/PaynowQR/issues"
  },
  "homepage": "https://github.com/ThunderQuoteTeam/PaynowQR#readme",
  "keywords": [
    "paynow",
    "SGQR",
    "Singapore",
    "sgpay",
    "qrcode",
    "payments"
  ]
}
